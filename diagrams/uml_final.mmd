classDiagram
    class Owner {
        +String name
        +List~Pet~ pets
        +Map~String, Task~ tasks
        +addPet(pet) void
        +addTask(task) void
        +removeTask(task) void
        +pending() List~Task~
        +completed() List~Task~
    }

    class Pet {
        +String name
        +Owner owner
        +Map~String, Task~ tasks
        +addTask(task) void
        +pending() List~Task~
        +completed() List~Task~
    }

    class Task {
        +String taskId
        +String description
        +Owner owner
        +Pet pet
        +int priority
        +DateTime scheduledTime
        +bool completed
        +Timedelta recurrence
        +addPriority(priority) void
        +isCompleted() bool
        +complete() Task
    }

    class Scheduler {
        +Map~String, Task~ tasks
        +schedule(task) void
        +unschedule(task) void
        +completeTask(task) Task
        +pending() List~Task~
        +completed() List~Task~
        +sortByTime(tasks) List~Task~
        +dueNow(now) List~Task~
        +findConflicts(tasks) List~List~Task~~
        +conflictWarnings(tasks) List~String~
    }

    class filter_tasks {
        <<function>>
        +filter_tasks(tasks, predicate) List~Task~
    }

    Owner "1" --> "0..*" Pet : owns
    Owner "1" --> "0..*" Task : manages
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "0..*" Task : schedules
    Scheduler ..> Pet : re-registers recurring task
    Scheduler ..> Owner : re-registers recurring task
    Task ..> Task : complete() spawns next occurrence
    Pet ..> filter_tasks : uses
    Scheduler ..> filter_tasks : uses
    Owner ..> filter_tasks : uses
